# Secrets — never commit. (The ~/.config/bmg/api_key file lives
# outside the repo by design; we don't need a pattern for it here.)
.env
.env.*
!.env.example

# Python build / install
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# Virtual envs
.venv/
venv/
env/

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.tox/
htmlcov/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# bmg runtime (state outside the repo is ignored by virtue of being
# outside; the /tmp/bmg-*/ pattern covers in-tree scratch dirs.)
/tmp/bmg-*/
.bmg.bak

# Local install state (regenerated by `bmg init --project`)
.claude/

# Developer-only continuity notes (kept on disk, not in the public
# repo — these are session-shaped, not user-facing documentation).
RESUME.md
WHAT_DIDNT_WORK.md

# defn workspace
.defn/

# Built binary (run `go build ./cmd/bmg`)
/bmg
/cmd/bmg/bmg
scratch/
